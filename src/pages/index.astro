---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Aldous | Portfolio">

<main class="hero reveal" id="home" data-bg="blue">

  <div class="hero-image">
    <img src={`${import.meta.env.BASE_URL}images/archie.jpeg`} />
  </div>

  <h1>Hi, I'm <span>Aldous</span></h1>

  <p>
    Computer Science Major • Web Developer • UI/UX Designer • Video Editor • Photo Editor • Tech Enthusiast
  </p>

  <div class="buttons">
    <a href="#projects">View Projects</a>
    <a href="#contact">Contact Me</a>
  </div>

</main>

  <section id="about" class="about reveal" data-bg="violet">
  <div class="about-container">

    <div class="about-image">
      <img src={`${import.meta.env.BASE_URL}images/archie.jpeg`} />
    </div>

    <div class="about-content">
      <h2>About Me</h2>

      <p>
        I'm Aldous, a Computer Science student passionate about building
        modern web applications, UI/UX designs, and multimedia content.
      </p>

      <p>
        I enjoy creating clean, user-friendly interfaces and solving real-world
        problems through code and design.
      </p>

      <div class="about-tags">
        <span>Web Development</span>
        <span>UI/UX Design</span>
        <span>Video Editing</span>
        <span>Photo Editing</span>
        <span>Problem Solving</span>
      </div>

    </div>

  </div>
</section>

<section class="tech-stack reveal" data-bg="cyan">

  <div class="section-header">
    <h2>Tech Stack</h2>
    <p>Tools and technologies I use</p>
  </div>

  <div class="tech-grid">

    <img src={`${import.meta.env.BASE_URL}images/Astro.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/React.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/Firebase.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/Python.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/MySQL.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/Node.js.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/HTML5.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/CSS3.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/JavaScript.svg`} />
   <img src={`${import.meta.env.BASE_URL}images/Git.svg`} />
    <img src={`${import.meta.env.BASE_URL}images/GitHub.svg`} />


  </div>

</section>

  <section id="projects" class="projects reveal" data-bg="gray">
  <div class="section-header">
    <h2>Featured Projects</h2>
    <p>Some of the things I've built</p>
  </div>

  <div class="projects-grid">

    <!-- Project 1 -->
    <div class="project-card">
      <img src={`${import.meta.env.BASE_URL}images/blog.png`} />

      <div class="project-content">
        <h3>Blog Site</h3>
        <p>
          a blog site created back in 2020, using html, css, js, and bootstrap to complete the website.
        </p>

        <div class="tags">
          <span>HTML</span>
          <span>CSS</span>
          <span>JS</span>
          <span>Bootstrap</span>
        </div>

        <div class="links">
          <a href="#">GitHub</a>
          <a href="#">Live Demo</a>
        </div>
      </div>
    </div>

    <!-- Project 2 -->
    <div class="project-card">
      <img src={`${import.meta.env.BASE_URL}images/laundryscience.png`} />

      <div class="project-content">
        <h3>Laundry Services Site</h3>
        <p>
          Full Site for a small laundry business using HTML, CSS, JS, Bootstrap, and Composer
        </p>

        <div class="tags">
          <span>HTML</span>
          <span>CSS</span>
          <span>Bootstrap</span>
          <span>JS</span>
          <span>Composer</span>
        </div>

        <div class="links">
          <a href="#">GitHub</a>
          <a href="#">Live Demo</a>
        </div>
      </div>
    </div>

    <!-- Project 3 -->
    <div class="project-card">
      <img src={`${import.meta.env.BASE_URL}images/adoption.png`} />

      <div class="project-content">
        <h3>Animal Sanctuary Based Site</h3>
        <p>
          Full Website for a small animal sanctuary using HMLT, CSS, JS, Firebase and SCSS
        </p>

        <div class="tags">
          <span>HTML</span>
          <span>CSS</span>
          <span>JS</span>
          <span>Firebase</span>
          <span>SCSS</span>
        </div>

        <div class="links">
          <a href="#">GitHub</a>
          <a href="#">Case Study</a>
        </div>
      </div>
    </div>

    <!-- Project 5 -->
    <div class="project-card">
      <img src={`${import.meta.env.BASE_URL}images/sucommunityapp.jpg`} />

      <div class="project-content">
        <h3>School Community App</h3>
        <p>
          Mobile School Community App with messaging, ordering, renting, and front page functions using React Native, Firebase, JS, and Node.js
        </p>

        <div class="tags">
          <span>React Native</span>
          <span>Firebase</span>
          <span>JS</span>
          <span>Node.js</span>
        </div>

        <div class="links">
          <a href="#">GitHub</a>
        </div>
      </div>
    </div>

    <div class="project-card">
      <img src={`${import.meta.env.BASE_URL}images/shopme.png`} />

      <div class="project-content">
        <h3>Shopping Web App</h3>
        <p>
          Shopping Web App, similar to shopee using only HTML & CSS for a short school project
        </p>

        <div class="tags">
          <span>HTML</span>
          <span>CSS</span>
          <span>JS</span>
          <span>Firebase</span>
          <span>SCSS</span>
        </div>

        <div class="links">
          <a href="#">GitHub</a>
          <a href="#">Live Demo</a>
        </div>
      </div>
    </div>

  </div>
  
</section>

<section id="skills" class="skills reveal" data-bg="deepblue">

  <div class="section-header">
    <h2>Skills & Tools</h2>
    <p>Technologies and tools I work with</p>
  </div>

  <div class="skills-grid">

    <!-- Web Dev -->
    <div class="skill-card">
      <h3>Web Development</h3>
      <div class="skill-list">
        <span>HTML</span>
        <span>CSS</span>
        <span>JavaScript</span>
        <span>PHP</span>
        <span>MySQL</span>
      </div>
    </div>

    <!-- Frameworks -->
    <div class="skill-card">
      <h3>Frameworks</h3>
      <div class="skill-list">
        <span>Astro</span>
        <span>React</span>
        <span>Node.js</span>
        <span>Tailwind</span>
      </div>
    </div>

    <!-- Design -->
    <div class="skill-card">
      <h3>Design</h3>
      <div class="skill-list">
        <span>Figma</span>
        <span>UI/UX</span>
        <span>Photoshop</span>
        <span>Canva</span>
      </div>
    </div>

    <!-- Media -->
    <div class="skill-card">
      <h3>Media & Editing</h3>
      <div class="skill-list">
        <span>Premiere Pro</span>
        <span>Final Cut Pro</span>
        <span>DaVinci Resolve</span>
      </div>
    </div>

    <!-- Tech -->
    <div class="skill-card">
      <h3>Technical Skills</h3>
      <div class="skill-list">
        <span>PC Building</span>
        <span>Hardware Diagnostics</span>
        <span>Troubleshooting</span>
      </div>
    </div>

  </div>

</section>

<section id="contact" class="contact reveal" data-bg="cyan">

  <div class="section-header">
    <h2>Contact Me</h2>
    <p>Let’s work together or build something cool</p>
  </div>

  <div class="contact-container">

    <!-- Left Info -->
    <div class="contact-info">

      <h3>Get in Touch</h3>

      <p>
        I'm open to freelance work, internships, and collaboration opportunities.
      </p>

      <div class="contact-links">
        <a href="mailto:jeanaldousnecesito@gmail.com">📧 Email Me</a>
        <a href="https://github.com/Dous13" target="_blank">💻 GitHub</a>
        <a href="https://www.linkedin.com/in/jean-aldous-necesito-8b56a7285/" target="_blank">🔗 LinkedIn</a>
      </div>

    </div>

    <!-- Contact Form -->
    <form class="contact-form">

      <input type="text" placeholder="Your Name" required />
      <input type="email" placeholder="Your Email" required />
      <textarea placeholder="Your Message" rows="6" required></textarea>

      <button type="submit">Send Message</button>

    </form>

  </div>

</section>

<footer class="footer reveal">

  <div class="footer-content">
    <h3>Aldous</h3>

    <p>
      Computer Science Major • Web Developer • UI/UX Designer • Photo & Video Editor • Tech Enthusiast
    </p>

    <div class="footer-links">
      <a href="#home">Home</a>
      <a href="#projects">Projects</a>
      <a href="#contact">Contact</a>
    </div>

    <p class="copyright">
      © 2026 Aldous. All rights reserved. Built with Care
    </p>
  </div>

</footer>

</BaseLayout>